# ============================================================
# SASL Transformer Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# REQUIRED: Your Anthropic API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# OPTIONAL: Claude model to use (default: claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# Sonnet is recommended for the best balance of quality and speed.
# Haiku is faster and cheaper but slightly less accurate on complex sentences.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OPTIONAL: Max tokens for translation response (default: 1024)
SASL_MAX_TOKENS=1024

# OPTIONAL: Temperature for translation (default: 0.1)
# Low = more consistent/deterministic, High = more creative
# Keep this low for translation consistency
SASL_TEMPERATURE=0.1

# OPTIONAL: Path to your sign library JSON file (default: data/sign_library.json)
SIGN_LIBRARY_PATH=data/sign_library.json

# OPTIONAL: Translation cache settings
SASL_CACHE_ENABLED=true
SASL_CACHE_MAX_SIZE=500
