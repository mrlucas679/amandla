# ============================================================
# AMANDLA Backend Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# ── Whisper speech-to-text settings ────────────────────────
# Model size: tiny | small | medium (small is the best balance)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en

# ── Ollama local AI settings ──────────────────────────────
# Ollama must be running: ollama serve
# Model must be created: ollama create amandla -f Modelfile
OLLAMA_MODEL=amandla
OLLAMA_BASE_URL=http://localhost:11434

# ── Backend server settings ───────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Optional: NVIDIA NIM fallback for speech-to-text ──────
# Only used when Whisper fails/times out and NVIDIA_ENABLED=true
# Get a free API key at https://build.nvidia.com
NVIDIA_ENABLED=false
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Optional: Anthropic API key (not currently used) ──────
ANTHROPIC_API_KEY=

# ── HARPS sign recognition settings ──────────────────────
HARPS_FEATURE_SET=SJ
HARPS_WINDOW=10
HARPS_STRIDE=3

# ── SASL Transformer cache settings ──────────────────────
SASL_CACHE_ENABLED=true
SASL_CACHE_MAX_SIZE=500
SIGN_LIBRARY_PATH=data/sign_library.json
